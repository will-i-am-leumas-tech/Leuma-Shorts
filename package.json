{
  "name": "leumas-clips-shorts",
  "version": "0.1.0",
  "description": "Node-first SDK and CLI for generating narrated vertical shorts from long-form text.",
  "type": "module",
  "main": "sdk/index.js",
  "exports": {
    ".": "./sdk/index.js"
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "test": "node --test tests/unit tests/integration",
    "test:unit": "node --test tests/unit",
    "test:integration": "node --test tests/integration",
    "test:env": "node scripts/test-env.js",
    "demo:assets": "node scripts/bootstrap-demo-assets.js",
    "generate": "node cli.js generate",
    "run:full-gameplay": "node scripts/run-full-gameplay.js",
    "run:split-layout": "node scripts/run-split-layout.js",
    "run:full-media": "node scripts/run-full-media.js",
    "run:auto-mode": "node scripts/run-auto-mode.js"
  },
  "keywords": [
    "video",
    "shorts",
    "ffmpeg",
    "reddit",
    "sdk",
    "tts"
  ],
  "license": "MIT"
}
